{
	"schemaVersion": 1,
	"id": "treeloghighlight",
	"version": "${version}",
	"name": "TreeLogHighlight",
	"description": "A Minecraft mod to highlight the remaining wood logs in a tree.",
	"authors": [
		"Alek"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/treeloghighlight/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"net.alek.treeloghighlight.TreeLogHighlight"
		],
		"client": [
			"net.alek.treeloghighlight.client.TreeLogHighlightClient"
		],
		"modmenu": [
			"net.alek.treeloghighlight.client.config.ModMenuIntegration"
		],
		"fabric-datagen": [
			"net.alek.treeloghighlight.client.TreeLogHighlightDataGenerator"
		]
	},
	"mixins": [
		"treeloghighlight.mixins.json",
		{
			"config": "treeloghighlight.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~1.21",
		"java": ">=21",
		"fabric-api": "*",
		"cloth-config2": "*",
		"modmenu": "*"
	}
}